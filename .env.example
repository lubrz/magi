# ============================================================================
# TRIAD — Multi-Agent Consensus System Configuration
# ============================================================================
# Copy this file to .env and configure as needed.
# ============================================================================

# --- Neo4j Connection ---
# Mode: "local" (Docker container) or "aura" (Neo4j AuraDB)
NEO4J_MODE=local
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=triad2026

# For AuraDB, uncomment and configure:
# NEO4J_MODE=aura
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-aura-password

# --- Embedding Model (for vector indexes) ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=sk-...
# Dimensions: 1536 for OpenAI text-embedding-3-small, 768 for Ollama nomic-embed-text
EMBEDDING_DIMENSIONS=1536

# Or use Ollama for local embeddings:
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768
# OLLAMA_URL=http://ollama:11434

# --- AXIOM Agent (Analytical) ---
AXIOM_PROVIDER=openai
AXIOM_MODEL=gpt-4o
AXIOM_API_KEY=sk-...

# --- PRISM Agent (Creative) ---
PRISM_PROVIDER=anthropic
PRISM_MODEL=claude-sonnet-4-20250514
PRISM_API_KEY=sk-ant-...

# --- FORGE Agent (Pragmatic) ---
FORGE_PROVIDER=google
FORGE_MODEL=gemini-2.5-flash
FORGE_API_KEY=AIza...

# --- ARBITER Agent (Judge) ---
ARBITER_PROVIDER=openai
ARBITER_MODEL=gpt-4o
ARBITER_API_KEY=sk-...

# --- All agents on local Ollama (alternative) ---
# AXIOM_PROVIDER=ollama
# AXIOM_MODEL=llama3.2
# PRISM_PROVIDER=ollama
# PRISM_MODEL=llama3.2
# FORGE_PROVIDER=ollama
# FORGE_MODEL=llama3.2
# OLLAMA_URL=http://ollama:11434

# --- Deliberation Settings ---
MAX_ROUNDS=3
CONSENSUS_THRESHOLD=0.7
CONSENSUS_MIN_VOTES=2

# --- Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
